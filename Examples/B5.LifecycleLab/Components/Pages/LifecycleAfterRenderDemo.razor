@page "/lifecycle-afterrender"
@rendermode InteractiveServer
@inject IJSRuntime JS

<PageTitle>OnAfterRender Demo</PageTitle>
<h2>OnAfterRender</h2>

<p>DOM이 렌더링된 후 실행됩니다. JS 연동이나 포커스 제어에 사용합니다.</p>

<div class="mb-3">
    <input id="focusTarget" class="form-control" @bind="inputValue" placeholder="자동 포커스 됩니다" />
</div>

<p><strong>렌더 횟수:</strong> @renderCount</p>
<p><strong>JS 알림:</strong> @jsMessage</p>

@code {
    private string inputValue = "";
    private int renderCount;
    private string jsMessage = "(대기 중)";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        renderCount++;
        if (firstRender)
        {
            await JS.InvokeVoidAsync("eval", "document.getElementById('focusTarget').focus()");
            jsMessage = "첫 렌더 후 JS 실행 완료";
        }
    }
}
