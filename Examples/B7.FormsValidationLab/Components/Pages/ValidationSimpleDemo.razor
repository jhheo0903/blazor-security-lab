@page "/validation-simple"
@rendermode InteractiveServer

<PageTitle>유효성 검사 Demo</PageTitle>
<h2>DataAnnotations 유효성 검사</h2>

<p>모델에 정의한 룰에 따라 입력값을 검증합니다.</p>

<div class="card">
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label">이름 (2-50자):</label>
            <input type="text" class="form-control" @bind="form.Name" placeholder="이름 입력" />
            @if (!string.IsNullOrEmpty(nameError))
            {
                <small class="text-danger d-block mt-1">@nameError</small>
            }
        </div>

        <div class="mb-3">
            <label class="form-label">이메일:</label>
            <input type="email" class="form-control" @bind="form.Email" placeholder="이메일 입력" />
            @if (!string.IsNullOrEmpty(emailError))
            {
                <small class="text-danger d-block mt-1">@emailError</small>
            }
        </div>

        <div class="mb-3">
            <label class="form-label">나이 (18-120):</label>
            <input type="number" class="form-control" @bind="form.Age" min="18" max="120" />
            @if (!string.IsNullOrEmpty(ageError))
            {
                <small class="text-danger d-block mt-1">@ageError</small>
            }
        </div>

        <button class="btn btn-primary" @onclick="Validate">검증</button>

        @if (isValid)
        {
            <div class="alert alert-success mt-3">
                <strong>검증 완료!</strong>
                <p>이름: @form.Name</p>
                <p>이메일: @form.Email</p>
                <p>나이: @form.Age</p>
            </div>
        }
    </div>
</div>

@code {
    private UserForm form = new();
    private string nameError = "";
    private string emailError = "";
    private string ageError = "";
    private bool isValid = false;

    private void Validate()
    {
        nameError = emailError = ageError = "";
        isValid = true;

        // 간단한 검증 (실제로는 ValidationContext 사용)
        if (string.IsNullOrEmpty(form.Name) || form.Name.Length < 2 || form.Name.Length > 50)
        {
            nameError = "이름은 2자 이상 50자 이하여야 합니다";
            isValid = false;
        }

        if (string.IsNullOrEmpty(form.Email) || !form.Email.Contains("@"))
        {
            emailError = "유효한 이메일을 입력하세요";
            isValid = false;
        }

        if (form.Age < 18 || form.Age > 120)
        {
            ageError = "나이는 18 이상 120 이하여야 합니다";
            isValid = false;
        }
    }
}
