<div class="card mb-3">
    <div class="card-body d-flex justify-content-between align-items-center">
        <div>
            <h5 class="card-title mb-1">@RuleName</h5>
            <p class="card-text mb-0">@Description</p>
        </div>
        <button class="btn btn-primary" @onclick="NotifyAsync">Apply</button>
    </div>
</div>

@code {
    [Parameter]
    public string RuleName { get; set; } = string.Empty;

    [Parameter]
    public string Description { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> OnApply { get; set; }

    private Task NotifyAsync() => OnApply.InvokeAsync(RuleName);
}
