@inject IJSRuntime JS

<!--
    MermaidDiagram.razor: Mermaid.js 다이어그램 렌더링 컴포넌트

    사용 방법:
      <MermaidDiagram Definition="@mermaidText" />

    동작 원리:
      1. Definition 프로퍼티로 Mermaid 텍스트를 받음
      2. OnAfterRenderAsync 에서 JSInterop 을 통해 mermaidInterop.render() 호출
      3. JS 함수가 mermaid.render() → SVG 생성 → DOM 에 삽입
-->

@if (!string.IsNullOrWhiteSpace(Definition))
{
    <div id="@_containerId" class="mermaid-container">
        <!-- Mermaid JS 가 이 div 에 SVG 를 삽입함 -->
        <div class="text-muted small text-center py-3">
            <div class="spinner-border spinner-border-sm me-2" role="status"></div>
            다이어그램 렌더링 중...
        </div>
    </div>
}
else
{
    <div class="alert alert-secondary">다이어그램 데이터가 없습니다.</div>
}

@code {
    /// <summary>Mermaid.js 다이어그램 정의 텍스트 (flowchart TD ... 등)</summary>
    [Parameter, EditorRequired]
    public string Definition { get; set; } = string.Empty;

    // 컴포넌트마다 고유한 DOM ID 생성 (같은 페이지에 여러 개 사용 가능)
    private string _containerId = $"mermaid-{Guid.NewGuid():N}";
    private string _prevDefinition = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Definition 이 바뀔 때마다 다시 렌더링
        if (Definition == _prevDefinition) return;
        _prevDefinition = Definition;

        if (!string.IsNullOrWhiteSpace(Definition))
        {
            try
            {
                // App.razor 에서 로드한 mermaid-interop.js 의 함수 호출
                await JS.InvokeVoidAsync("mermaidInterop.render", _containerId, Definition);
            }
            catch (Exception ex)
            {
                // JSInterop 실패 시 콘솔에만 출력 (페이지 크래시 방지)
                Console.WriteLine($"Mermaid 렌더링 실패: {ex.Message}");
            }
        }
    }
}
