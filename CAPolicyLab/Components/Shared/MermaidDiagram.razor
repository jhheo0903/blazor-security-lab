@inject IJSRuntime JS

@if (!string.IsNullOrWhiteSpace(Definition))
{
    <div class="mermaid-wrapper" data-mermaid-id="@_containerId">

        <!-- 툴바 -->
        <div class="mermaid-toolbar">
            <div class="d-flex align-items-center gap-1">
                <button class="mermaid-btn" @onclick="ZoomIn" title="확대">
                    <i class="bi bi-plus-lg"></i>
                </button>
                <button class="mermaid-btn" @onclick="ZoomOut" title="축소">
                    <i class="bi bi-dash-lg"></i>
                </button>
                <span class="mermaid-zoom-pct">100%</span>
            </div>
            <div class="d-flex align-items-center gap-1">
                <button class="mermaid-btn" @onclick="FitToScreen" title="화면에 맞추기">
                    <i class="bi bi-fullscreen"></i>
                </button>
                <button class="mermaid-btn" @onclick="ResetZoom" title="원래 크기 (100%)">
                    <i class="bi bi-aspect-ratio"></i>
                </button>
            </div>
            <span class="mermaid-hint">드래그 이동 · 휠 줌</span>
        </div>

        <!-- 다이어그램 캔버스 -->
        <div id="@_containerId" class="mermaid-container">
            <div class="text-muted small text-center" style="padding:2rem 0;">
                <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                다이어그램 렌더링 중...
            </div>
        </div>

    </div>
}
else
{
    <div class="alert alert-secondary small">다이어그램 데이터가 없습니다.</div>
}

@code {
    [Parameter, EditorRequired]
    public string Definition { get; set; } = string.Empty;

    private string _containerId    = $"mermaid-{Guid.NewGuid():N}";
    private string _prevDefinition = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Definition == _prevDefinition) return;
        _prevDefinition = Definition;

        if (string.IsNullOrWhiteSpace(Definition)) return;

        try
        {
            await JS.InvokeVoidAsync("mermaidInterop.render", _containerId, Definition);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[MermaidDiagram] 렌더링 실패: {ex.Message}");
        }
    }

    private async Task ZoomIn()       => await JS.InvokeVoidAsync("mermaidInterop.zoomIn",       _containerId);
    private async Task ZoomOut()      => await JS.InvokeVoidAsync("mermaidInterop.zoomOut",      _containerId);
    private async Task ResetZoom()    => await JS.InvokeVoidAsync("mermaidInterop.resetZoom",    _containerId);
    private async Task FitToScreen()  => await JS.InvokeVoidAsync("mermaidInterop.fitToScreen",  _containerId);
}
