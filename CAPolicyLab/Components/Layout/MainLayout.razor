@inherits LayoutComponentBase

<!-- MainLayout.razor: 전체 레이아웃 + 상단 인증 상태 표시 -->
<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <!-- 상단 바: 인증된 사용자 정보 표시 -->
        <div class="top-row px-4 d-flex justify-content-between align-items-center">
            <span class="text-muted small">
                <i class="bi bi-shield-check text-success me-1"></i>
                Conditional Access Policy Lab
            </span>
            <!-- AuthorizeView: 인증 상태에 따라 다른 UI를 렌더링 -->
            <AuthorizeView>
                <Authorized>
                    <!-- context.User : ClaimsPrincipal → 현재 로그인 사용자 -->
                    <span class="small">
                        <i class="bi bi-person-circle me-1 text-primary"></i>
                        <strong>@context.User.Identity?.Name</strong>
                    </span>
                </Authorized>
                <NotAuthorized>
                    <a class="btn btn-sm btn-outline-primary"
                       href="MicrosoftIdentity/Account/SignIn">
                        <i class="bi bi-box-arrow-in-right me-1"></i>로그인
                    </a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            <!-- 페이지 별 콘텐츠가 여기 렌더링됨 -->
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    처리되지 않은 오류가 발생했습니다.
    <a href="." class="reload">새로고침</a>
    <span class="dismiss">🗙</span>
</div>
