@inherits LayoutComponentBase
@inject AppConfigService ConfigService

<!-- MainLayout.razor: 전체 레이아웃 -->
<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <!-- 상단 바 -->
        <div class="top-row px-4 d-flex justify-content-between align-items-center">
            <span class="text-muted small">
                <i class="bi bi-shield-check text-success me-1"></i>
                Conditional Access Policy Lab
            </span>
            @if (ConfigService.GetStatus() == ConfigStatus.Configured)
            {
                <span class="badge bg-success-subtle text-success border border-success-subtle small">
                    <i class="bi bi-check-circle me-1"></i>앱 권한 연결됨
                </span>
            }
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    처리되지 않은 오류가 발생했습니다.
    <a href="." class="reload">새로고침</a>
    <span class="dismiss">🗙</span>
</div>
